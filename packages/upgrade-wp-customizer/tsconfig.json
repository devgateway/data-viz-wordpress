{
    "compilerOptions": {
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "target": "ES2022",
        "module": "ES2020",
        "skipLibCheck": true,
        "outDir": "./dist",
        "declaration": true,
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "noEmit": false,
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "allowJs": true,
        "noImplicitAny": false,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "templates"
    ]
}
