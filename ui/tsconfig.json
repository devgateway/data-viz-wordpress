{
  "***REMOVED***": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "***REMOVED***": "bundler",
    "allowImportingTsExtensions": true,
    "***REMOVED***": true,
    "***REMOVED***": true,
    "noEmit": true,
    "jsx": "react",

    /* Linting */
    "strict": true,
    "***REMOVED***": true,
    "***REMOVED***": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"] 
    }
  },
  "files": [],
  "include": ["src"],
  "references": [
    { "path": "./tsconfig.node.json" }
  ]
}
