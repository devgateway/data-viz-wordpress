{
  "name": "data-viz-wordpress",
  "contributors": [
    "Sebastian Dimunzio",
    "Timothy Mugo"
  ],
  "version": "1.0.0",
  "private": true,
  "description": "Wordpress Repository for Data Viz that contains plugins and blocks for the Data Viz plugin",
  "workspaces": [
    "packages/*",
    "plugins/*/*",
    "!plugins/wp-react-custom-multilang/**"
  ],
  "scripts": {
    "build": "pnpm recursive run build",
    "build:npm-packages": "pnpm --filter='@devgateway/dvz-wp-commons' --filter='@devgateway/create-wp-customizer' --filter='@devgateway/upgrade-wp-customizer' build",
    "version": "changeset version",
    "release": "changeset publish",
    "publish:next": "changeset publish --next",
    "publish:dev": "changeset publish --dev",
    "publish:ci": "changeset publish --ci"
  },
  "keywords": [
    "wordpress",
    "data-viz",
    "data-viz-wordpress",
    "dg-data-viz",
    "devgateway"
  ],
  "author": "Development Gateway",
  "license": "GPL-2.0-or-later",
  "packageManager": "pnpm@10.18.1",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@wordpress/scripts": "^30.25.0"
  }
}
