{
  "name": "@devgateway/customizer",
  "version": "0.1.0",
  "author": "Sebastian Dimunzio <sdimunzio@***REMOVED***.org/>",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "files": [
    "dist",
    "dist/css",
    "README.md"
  ],
  "license": "MIT",
  "dependencies": { 
    "watch": "^1.0.2"
  },
  "***REMOVED***": {
    "@babel/cli": "^7.25.9",
    "@babel/preset-env": "^7.25.9",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/plugin-external-helpers": "^7.25.9",
    "@babel/preset-react": "^7.13.13",
    "babel-plugin-react-compiler": "^19.0.0-beta-a7bf2bd-20241110",
    "react-compiler-runtime": "^19.0.0-beta-a7bf2bd-20241110",
    "sass": "^1.79.4"
  },
  "***REMOVED***": {
    "react": "*",
    "react-dom": "*",
    "react-redux": "*",
    "semantic-ui-react": "*",
    "immutable": "*"
  },
  "scripts": {
    "dist": "rm -rf dist && sass ./src/scss:./dist/css &&  babel src/ -d dist --copy-files  && npm link",
    "css_dist": "sass ./src/scss:./dist/css",
    "watch": "watch 'npm run dist ' ./src",
    "css": "watch 'npm run css_dist ' ./src"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "modules": false
        }
      ],
      [
        "@babel/preset-react",
        {
          "runtime": "automatic"
        }
      ]
    ],
    "plugins": [
      [
        "babel-plugin-react-compiler",
        {
          "target": "18"
        }
      ],
      "@babel/plugin-transform-runtime",
      "@babel/plugin-external-helpers"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devgateway/dg-wp-react.git"
  },
  "keywords": [
    "react"
  ]
}
